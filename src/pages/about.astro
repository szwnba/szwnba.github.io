---
import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout title="系统详情 - szwnba Collector">
  <div class="max-w-3xl mx-auto px-6 py-12">
    <h1 class="text-4xl font-bold mb-2" data-i18n="about.title">系统详情 🔧</h1>
    <p class="text-[var(--text-dim)] mb-8 text-lg" data-i18n="about.intro">
      一个运行中的 AI 采集与知识管理系统。以下是完整的系统配置和运行状态。
    </p>

    <!-- 基础系统 -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-4" data-i18n="about.systemInfo.title">🖥️ 基础系统</h2>
      <div class="space-y-3 text-[var(--text-dim)]">
        <div class="p-4 bg-[var(--bg-card)] rounded-2xl border border-[var(--border)]">
          <span class="font-semibold text-[var(--text)]">OS：</span>
          <span data-i18n="about.systemInfo.os">Ubuntu 20.04.6 LTS (Focal Fossa)</span>
        </div>
        <div class="p-4 bg-[var(--bg-card)] rounded-2xl border border-[var(--border)]">
          <span class="font-semibold text-[var(--text)]">内核：</span>
          <span data-i18n="about.systemInfo.kernel">Linux 5.4.0-208-generic x86_64</span>
        </div>
        <div class="p-4 bg-[var(--bg-card)] rounded-2xl border border-[var(--border)]">
          <span class="font-semibold text-[var(--text)]">内存：</span>
          <span data-i18n="about.systemInfo.memory">3.8 GB RAM · 3.8 GB Swap</span>
        </div>
        <div class="p-4 bg-[var(--bg-card)] rounded-2xl border border-[var(--border)]">
          <span class="font-semibold text-[var(--text)]">磁盘：</span>
          <span data-i18n="about.systemInfo.disk">157 GB (已用 70G / 可用 80G · 47%)</span>
        </div>
        <div class="p-4 bg-[var(--bg-card)] rounded-2xl border border-[var(--border)]">
          <span class="font-semibold text-[var(--text)]">Python：</span>
          <span data-i18n="about.systemInfo.python">Python 3.12.0 (pyenv)</span>
        </div>
        <div class="p-4 bg-[var(--bg-card)] rounded-2xl border border-[var(--border)]">
          <span class="font-semibold text-[var(--text)]">Node：</span>
          <span data-i18n="about.systemInfo.node">Node.js v24.14.0</span>
        </div>
      </div>
    </section>

    <!-- Hermes -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-4" data-i18n="about.hermesInfo.title">🤖 Hermes Agent</h2>
      <div class="space-y-3 text-[var(--text-dim)]">
        <div class="p-4 bg-[var(--bg-card)] rounded-2xl border border-[var(--border)]">
          <span class="font-semibold text-[var(--text)]">版本：</span>
          <span data-i18n="about.hermesInfo.version">v0.17.0 (2026.6.19)</span>
        </div>
        <div class="p-4 bg-[var(--bg-card)] rounded-2xl border border-[var(--border)]">
          <span class="font-semibold text-[var(--text)]">Profile：</span>
          <span data-i18n="about.hermesInfo.profile">collector（活跃）</span>
        </div>
        <div class="p-4 bg-[var(--bg-card)] rounded-2xl border border-[var(--border)]">
          <span class="font-semibold text-[var(--text)]">运行时：</span>
          <span data-i18n="about.hermesInfo.pythonRuntime">Python 3.11.11 / OpenAI SDK 2.24.0</span>
        </div>
      </div>
    </section>

    <!-- 知识库 -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-4" data-i18n="about.collectedContent.title">📚 知识库（采集内容）</h2>
      <div class="space-y-3 text-[var(--text-dim)]">
        <div class="p-4 bg-[var(--bg-card)] rounded-2xl border border-[var(--border)]">
          <span class="font-semibold text-[var(--text)]">00_Inbox：</span>
          <span data-i18n="about.collectedContent.inbox">332 篇文章</span>
        </div>
        <div class="p-4 bg-[var(--bg-card)] rounded-2xl border border-[var(--border)]">
          <span class="font-semibold text-[var(--text)]">20_Wiki：</span>
          <span data-i18n="about.collectedContent.wiki">10 个主题页面</span>
        </div>
        <div class="p-4 bg-[var(--bg-card)] rounded-2xl border border-[var(--border)]">
          <span class="font-semibold text-[var(--text)]">30_Outputs：</span>
          <span data-i18n="about.collectedContent.output">1 份分析报告</span>
        </div>
      </div>
      <div data-categories-grid class="grid grid-cols-1 sm:grid-cols-2 gap-3 mt-4"></div>
    </section>

    <!-- Cron -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-4" data-i18n="about.cronJobs.title">⏰ Cron 自动化任务</h2>
      <div data-cron-grid class="space-y-3"></div>
    </section>

    <div class="mt-8 pt-8 border-t border-[var(--border)] text-center">
      <a href="https://github.com/szwnba" class="text-[var(--accent)] hover:underline font-medium">GitHub →</a>
      <span class="mx-4 text-[var(--text-muted)]">·</span>
      <a href="/projects" class="text-[var(--accent)] hover:underline font-medium" data-i18n="nav.projects">技能列表</a>
    </div>
  </div>
</BaseLayout>

<script>
  const CATEGORIES_ZH = [
    { emoji: '🦞', name: 'OpenClaw', count: 41 },
    { emoji: '🎭', name: 'Playwright AI', count: 40 },
    { emoji: '🧪', name: '测试工程', count: 37 },
    { emoji: '📈', name: '投资与变现', count: 36 },
    { emoji: '🌐', name: '浏览器自动化', count: 27 },
    { emoji: '🤖', name: 'AI Skill', count: 24 },
    { emoji: '💡', name: 'AI 理念与范式', count: 23 },
    { emoji: '⌨️', name: 'Claude Code & OpenCode', count: 23 },
    { emoji: '🚀', name: 'Onboarding', count: 21 },
    { emoji: '🧠', name: 'AI Agent', count: 15 },
    { emoji: '🔧', name: '开源工具', count: 10 },
    { emoji: '⚡', name: 'Hermes', count: 10 },
  ]
  const CATEGORIES_EN = [
    { emoji: '🦞', name: 'OpenClaw', count: 41 },
    { emoji: '🎭', name: 'Playwright AI', count: 40 },
    { emoji: '🧪', name: 'Test Engineering', count: 37 },
    { emoji: '📈', name: 'Investment', count: 36 },
    { emoji: '🌐', name: 'Browser Automation', count: 27 },
    { emoji: '🤖', name: 'AI Skill', count: 24 },
    { emoji: '💡', name: 'AI Philosophy', count: 23 },
    { emoji: '⌨️', name: 'Claude Code & OpenCode', count: 23 },
    { emoji: '🚀', name: 'Onboarding', count: 21 },
    { emoji: '🧠', name: 'AI Agent', count: 15 },
    { emoji: '🔧', name: 'Open Source Tools', count: 10 },
    { emoji: '⚡', name: 'Hermes', count: 10 },
  ]

  const CRONS_ZH = [
    { emoji: '📡', name: '情报官每日简报', time: '每日 8:00', desc: '采集 GitHub / arXiv / RSS 的 AI/Agent 情报' },
    { emoji: '🧪', name: 'AI 测试情报采集', time: '每日 20:00', desc: 'AI 驱动的自动化测试领域动态追踪' },
    { emoji: '🌟', name: 'GitHub 项目发现', time: '每日 9:00', desc: 'GitHub Trending 上的 AI 项目推荐' },
    { emoji: '🔄', name: 'Todoist×KB 匹配', time: '12:00 / 20:00 / 23:00', desc: '每日 3 次，关联 Todoist 任务与知识库' },
  ]
  const CRONS_EN = [
    { emoji: '📡', name: 'Intel Daily Brief', time: 'Daily 8:00', desc: 'AI/Agent intel from GitHub / arXiv / RSS' },
    { emoji: '🧪', name: 'AI Test Collection', time: 'Daily 20:00', desc: 'AI-driven automated testing trends' },
    { emoji: '🌟', name: 'GitHub Discovery', time: 'Daily 9:00', desc: 'AI projects from GitHub Trending' },
    { emoji: '🔄', name: 'Todoist×KB Match', time: '12:00 / 20:00 / 23:00', desc: '3× daily, links tasks with KB' },
  ]

  function renderCategories(items: typeof CATEGORIES_ZH) {
    return items.map(c =>
      `<div class="p-3 bg-[var(--bg-card)] rounded-2xl border border-[var(--border)] flex items-center gap-3">
        <span class="text-xl">${c.emoji}</span>
        <div class="flex-1">
          <div class="font-semibold text-sm">${c.name}</div>
        </div>
        <div class="text-[var(--accent)] font-bold">${c.count} 篇</div>
      </div>`
    ).join('')
  }

  function renderCrons(items: typeof CRONS_ZH) {
    return items.map(c =>
      `<div class="p-4 bg-[var(--bg-card)] rounded-2xl border border-[var(--border)]">
        <div class="flex items-center gap-3">
          <span class="text-xl">${c.emoji}</span>
          <div class="flex-1">
            <div class="font-semibold">${c.name}</div>
            <div class="text-xs text-[var(--text-muted)]">${c.time}</div>
          </div>
        </div>
        <p class="mt-2 text-sm text-[var(--text-dim)] pl-9">${c.desc}</p>
      </div>`
    ).join('')
  }

  function getLang(): 'zh' | 'en' {
    const l = document.documentElement.getAttribute('data-lang')
    return l === 'en' ? 'en' : 'zh'
  }

  function render() {
    const lang = getLang()
    const cats = lang === 'en' ? CATEGORIES_EN : CATEGORIES_ZH
    const crons = lang === 'en' ? CRONS_EN : CRONS_ZH
    const catGrid = document.querySelector('[data-categories-grid]')
    if (catGrid) catGrid.innerHTML = renderCategories(cats)
    const cronGrid = document.querySelector('[data-cron-grid]')
    if (cronGrid) cronGrid.innerHTML = renderCrons(crons)
  }

  window.addEventListener('langchange', () => render())
  render()
</script>