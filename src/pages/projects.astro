---
import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout title="技能与工具 - szwnba Collector">
  <div class="max-w-4xl mx-auto px-6 py-12">
    <h1 class="text-4xl font-bold mb-2 text-center" data-i18n="projects.title">技能与工具 🛠️</h1>
    <p class="text-[var(--text-dim)] text-center mb-12" data-i18n="projects.subtitle">
      已安装的 45 个技能（其中 6 个自主开发），覆盖 9 个类别。已清理 28 个闲置技能。
    </p>

    <div data-skills-grid class="grid grid-cols-1 md:grid-cols-2 gap-6"></div>
  </div>
</BaseLayout>

<script>
  const SKILLS_ZH = [
    { emoji: '🏆', name: '自主开发', skills: 'hybrid-web-scraper, intelligence-agent-builder, knowledge-base-utilization, todoist, obsidian-bookmark-import, github-repo-audit', desc: '自研核心技能：网页采集、情报监控、知识库分析、任务管理', count: 6 },
    { emoji: '🛠️', name: '核心集成', skills: 'hermes-agent, obsidian, opencode, jupyter-live-kernel, google-workspace, arxiv, blogwatcher, last30days, dogfood', desc: '日常依赖：Hermes 框架、笔记、编码代理、数据分析、研究', count: 9 },
    { emoji: '🐙', name: 'GitHub', skills: 'repo-management, github-auth, codebase-inspection, code-review, issues, pr-workflow', desc: '仓库管理、身份认证、代码审查、Issue/PR 工作流', count: 6 },
    { emoji: '🔬', name: '研究与情报', skills: 'blogwatcher, arxiv, last30days, llm-wiki, polymarket', desc: '博客监控、论文搜索、跨平台调研、知识维基', count: 5 },
    { emoji: '💻', name: '开发工具', skills: 'plan, spike, simplify-code, systematic-debugging, tdd, python-debugpy, skill-authoring, code-review-request', desc: '规划、实验、简化、调试、测试全流程工具', count: 8 },
    { emoji: '⚡', name: '生产力', skills: 'nano-pdf, notion, powerpoint, popular-web-designs, kanban', desc: 'PDF 编辑、笔记、演示文稿、设计系统模板', count: 5 },
    { emoji: '🎨', name: '设计', skills: 'popular-web-designs', desc: '54 个真实设计系统（Stripe, Linear, Vercel）', count: 1 },
    { emoji: '🌐', name: '多平台', skills: 'yuanbao, xurl, evaluating-llms-harness', desc: '飞书集成、Twitter API、LLM 评估基准', count: 3 },
    { emoji: '📦', name: '默认 Profile（可删）', skills: 'claude-code, codex, serving-llms-vllm, audiocraft, segment-anything', desc: '内置但在 collector profile 不可用，待清理', count: 5 },
  ]

  const SKILLS_EN = [
    { emoji: '🏆', name: 'Custom Built', skills: 'hybrid-web-scraper, intelligence-agent-builder, knowledge-base-utilization, todoist, obsidian-bookmark-import, github-repo-audit', desc: 'Self-developed: web scraping, intel monitoring, KB analysis, task mgmt', count: 6 },
    { emoji: '🛠️', name: 'Core Integration', skills: 'hermes-agent, obsidian, opencode, jupyter-live-kernel, google-workspace, arxiv, blogwatcher, last30days, dogfood', desc: 'Daily drivers: Hermes, notes, coding agents, research', count: 9 },
    { emoji: '🐙', name: 'GitHub', skills: 'repo-management, github-auth, codebase-inspection, code-review, issues, pr-workflow', desc: 'Repo mgmt, auth, code review, issues & PR workflows', count: 6 },
    { emoji: '🔬', name: 'Research & Intel', skills: 'blogwatcher, arxiv, last30days, llm-wiki, polymarket', desc: 'Blog monitoring, paper search, multi-platform research', count: 5 },
    { emoji: '💻', name: 'Dev Tools', skills: 'plan, spike, simplify-code, systematic-debugging, tdd, python-debugpy, skill-authoring, code-review-request', desc: 'Planning, experiments, debugging, testing toolchain', count: 8 },
    { emoji: '⚡', name: 'Productivity', skills: 'nano-pdf, notion, powerpoint, popular-web-designs, kanban', desc: 'PDF editing, notes, presentations, design templates', count: 5 },
    { emoji: '🎨', name: 'Design', skills: 'popular-web-designs', desc: '54 real design systems (Stripe, Linear, Vercel)', count: 1 },
    { emoji: '🌐', name: 'Multi-Platform', skills: 'yuanbao, xurl, evaluating-llms-harness', desc: 'Feishu, Twitter API, LLM evaluation benchmarks', count: 3 },
    { emoji: '📦', name: 'Default Profile (cleanup)', skills: 'claude-code, codex, serving-llms-vllm, audiocraft, segment-anything', desc: 'Bundled but unavailable in collector profile, pending cleanup', count: 5 },
  ]

  function renderSkills(items: typeof SKILLS_ZH) {
    return items.map(s =>
      `<article class="p-5 bg-[var(--bg-card)] rounded-2xl border border-[var(--border)] hover:border-[var(--accent)] transition-colors card-hover">
        <div class="flex items-center gap-3 mb-3">
          <span class="text-2xl">${s.emoji}</span>
          <div>
            <h2 class="text-lg font-bold">${s.name}</h2>
            <div class="text-xs text-[var(--text-muted)]">${s.count} 个技能</div>
          </div>
        </div>
        <p class="text-[var(--text-dim)] text-sm mb-3">${s.desc}</p>
        <div class="text-xs text-[var(--accent)] font-mono">${s.skills}</div>
      </article>`
    ).join('')
  }

  function getLang(): 'zh' | 'en' {
    const l = document.documentElement.getAttribute('data-lang')
    return l === 'en' ? 'en' : 'zh'
  }

  function render() {
    const lang = getLang()
    const items = lang === 'en' ? SKILLS_EN : SKILLS_ZH
    const grid = document.querySelector('[data-skills-grid]')
    if (grid) grid.innerHTML = renderSkills(items)
  }

  window.addEventListener('langchange', () => render())
  render()
</script>