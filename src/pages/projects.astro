---
import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout title="技能与工具 - szwnba Collector">
  <div class="max-w-4xl mx-auto px-6 py-12">
    <h1 class="text-4xl font-bold mb-2 text-center" data-i18n="projects.title">技能与工具 🛠️</h1>
    <p class="text-[var(--text-dim)] text-center mb-12" data-i18n="projects.subtitle">
      已安装的 73 个技能，覆盖 13 个类别。点击查看详情。
    </p>

    <div data-skills-grid class="grid grid-cols-1 md:grid-cols-2 gap-6"></div>
  </div>
</BaseLayout>

<script>
  const SKILLS_ZH = [
    { emoji: '🤖', name: '自主 AI Agent', skills: 'Claude Code, Codex, Hermes Agent, OpenCode', desc: '编码代理编排与任务委派', count: 4 },
    { emoji: '🎨', name: '创意生成', skills: 'ASCII Art, Excalidraw, p5.js, Manim, ComfyUI, Baoyu 等', desc: 'ASCII 艺术、架构图、手绘风格、3D 动画、图像生成', count: 13 },
    { emoji: '📊', name: '数据科学', skills: 'Hybrid Web Scraper, Jupyter', desc: '网页采集 + 交互式数据分析', count: 2 },
    { emoji: '🐙', name: 'GitHub 工作流', skills: 'Code Review, PR Workflow, Issues, Auth, Repo Mgmt 等', desc: '完整的 GitHub 操作链：审查、合并、管理', count: 6 },
    { emoji: '🎵', name: '媒体处理', skills: 'YouTube Transcript, GIF Search, HeartMuLa, Songsee', desc: '音视频内容提取与生成', count: 4 },
    { emoji: '🧬', name: 'MLOps', skills: 'llama.cpp, vLLM, HuggingFace Hub, lm-eval, W&B, SAM 等', desc: '模型推理、评估、部署全套工具链', count: 7 },
    { emoji: '📝', name: '笔记管理', skills: 'Obsidian', desc: '知识库读写查询', count: 1 },
    { emoji: '⚡', name: '生产力工具', skills: 'Airtable, Google Workspace, Intel Agent, Maps, PDF, Notion, PPT 等', desc: '办公自动化、文档处理、智能体构建', count: 10 },
    { emoji: '🔬', name: '研究与情报', skills: 'arXiv, Blogwatcher, last30days, LLM Wiki, Polymarket 等', desc: '学术搜索、博客监控、多平台调研', count: 7 },
    { emoji: '💻', name: '软件开发', skills: 'Debugger, TDD, Code Review, Plan, Spike, Simplifier 等', desc: '开发全流程：调试、测试、计划、简化', count: 8 },
    { emoji: '📧', name: '邮件', skills: 'Himalaya CLI', desc: 'IMAP/SMTP 终端邮件', count: 1 },
    { emoji: '🐦', name: '社交媒体', skills: 'xurl (X/Twitter)', desc: 'Twitter v2 API 发布与搜索', count: 1 },
    { emoji: '💡', name: '智能家居', skills: 'OpenHue', desc: 'Philips Hue 灯光控制', count: 1 },
  ]

  const SKILLS_EN = [
    { emoji: '🤖', name: 'Autonomous AI Agents', skills: 'Claude Code, Codex, Hermes Agent, OpenCode', desc: 'Coding agent orchestration & task delegation', count: 4 },
    { emoji: '🎨', name: 'Creative Generation', skills: 'ASCII Art, Excalidraw, p5.js, Manim, ComfyUI, Baoyu + more', desc: 'ASCII art, arch diagrams, hand-drawn, 3D animation', count: 13 },
    { emoji: '📊', name: 'Data Science', skills: 'Hybrid Web Scraper, Jupyter', desc: 'Web scraping + interactive data analysis', count: 2 },
    { emoji: '🐙', name: 'GitHub Workflows', skills: 'Code Review, PR Workflow, Issues, Auth, Repo Mgmt + more', desc: 'Full GitHub ops chain: review, merge, manage', count: 6 },
    { emoji: '🎵', name: 'Media Processing', skills: 'YouTube Transcript, GIF Search, HeartMuLa, Songsee', desc: 'Audio/video extraction and generation', count: 4 },
    { emoji: '🧬', name: 'MLOps', skills: 'llama.cpp, vLLM, HuggingFace Hub, lm-eval, W&B, SAM + more', desc: 'Model inference, evaluation, deployment', count: 7 },
    { emoji: '📝', name: 'Note Taking', skills: 'Obsidian', desc: 'Knowledge base read/write/query', count: 1 },
    { emoji: '⚡', name: 'Productivity', skills: 'Airtable, GWS, Intel Agent, Maps, PDF, Notion, PPT + more', desc: 'Office automation, document processing', count: 10 },
    { emoji: '🔬', name: 'Research & Intel', skills: 'arXiv, Blogwatcher, last30days, LLM Wiki, Polymarket + more', desc: 'Academic search, blog monitoring, research', count: 7 },
    { emoji: '💻', name: 'Software Dev', skills: 'Debugger, TDD, Code Review, Plan, Spike, Simplifier + more', desc: 'Full dev cycle: debug, test, plan, simplify', count: 8 },
    { emoji: '📧', name: 'Email', skills: 'Himalaya CLI', desc: 'IMAP/SMTP terminal email', count: 1 },
    { emoji: '🐦', name: 'Social Media', skills: 'xurl (X/Twitter)', desc: 'Twitter v2 API posting & search', count: 1 },
    { emoji: '💡', name: 'Smart Home', skills: 'OpenHue', desc: 'Philips Hue light control', count: 1 },
  ]

  function renderSkills(items: typeof SKILLS_ZH) {
    return items.map(s =>
      `<article class="p-5 bg-[var(--bg-card)] rounded-2xl border border-[var(--border)] hover:border-[var(--accent)] transition-colors card-hover">
        <div class="flex items-center gap-3 mb-3">
          <span class="text-2xl">${s.emoji}</span>
          <div>
            <h2 class="text-lg font-bold">${s.name}</h2>
            <div class="text-xs text-[var(--text-muted)]">${s.count} 个技能</div>
          </div>
        </div>
        <p class="text-[var(--text-dim)] text-sm mb-3">${s.desc}</p>
        <div class="text-xs text-[var(--accent)] font-mono">${s.skills}</div>
      </article>`
    ).join('')
  }

  function getLang(): 'zh' | 'en' {
    const l = document.documentElement.getAttribute('data-lang')
    return l === 'en' ? 'en' : 'zh'
  }

  function render() {
    const lang = getLang()
    const items = lang === 'en' ? SKILLS_EN : SKILLS_ZH
    const grid = document.querySelector('[data-skills-grid]')
    if (grid) grid.innerHTML = renderSkills(items)
  }

  window.addEventListener('langchange', () => render())
  render()
</script>