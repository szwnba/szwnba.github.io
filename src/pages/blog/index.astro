---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { DEFAULT_LANG, type Lang } from '../../i18n'

const pageLang: Lang = DEFAULT_LANG
---

<BaseLayout
  title={pageLang === 'en' ? 'Knowledge Base - szwnba Collector' : '知识库 - szwnba 采集系统'}
  description={
    pageLang === 'en'
      ? '332 articles · 12 categories · Continuously updated knowledge base'
      : '332 篇文章 · 12 个分类 · 持续更新的知识库'
  }
>
  <div class="max-w-3xl mx-auto px-6 py-12">
    <h1 class="text-4xl font-bold mb-2" data-i18n="blog.title">
      {pageLang === 'en' ? 'Knowledge Base 📚' : '知识库 📚'}
    </h1>
    <p class="text-[var(--text-dim)] mb-8" data-i18n="blog.subtitle">
      {pageLang === 'en'
        ? '332 articles · 12 categories · Continuously updated'
        : '332 篇采集文章 · 12 个分类 · 持续更新中'}
    </p>

    <!-- KB Overview -->
    <div class="p-6 bg-[var(--bg-card)] rounded-3xl border border-[var(--border)] mb-8">
      <h2 class="text-2xl font-bold mb-4">
        {pageLang === 'en' ? '📊 KB Overview' : '📊 知识库概览'}
      </h2>
      <div class="space-y-2 text-[var(--text-dim)] text-sm">
        <p>📍 <strong>00_Inbox</strong> — 332 篇原始采集文章</p>
        <p>📍 <strong>20_Wiki</strong> — 10 个主题整理页面</p>
        <p>📍 <strong>30_Outputs</strong> — 1 份全景分析报告</p>
        <p>📍 <strong>采集工具</strong> — Hybrid Web Scraper (Playwright + Tavily + Crawl4AI)</p>
        <p>📍 <strong>存储路径</strong> — <code class="text-[var(--accent)]">/root/Documents/Obsidian Vault/</code></p>
      </div>
    </div>

    <!-- Categories -->
    <div class="grid grid-cols-1 gap-3">
      <div data-cat-OpenClaw class="p-4 bg-[var(--bg-card)] rounded-2xl border border-[var(--border)] hover:border-[var(--accent)] transition-colors card-hover">
        <div class="flex items-center gap-3">
          <span class="text-2xl">🦞</span>
          <div class="flex-1"><h3 class="font-semibold">OpenClaw</h3></div>
          <span class="text-[var(--accent)] font-bold">41 篇</span>
        </div>
        <p class="text-xs text-[var(--text-muted)] mt-2">OpenClaw 框架、自动化测试、Clawd 系统</p>
      </div>
      <div class="p-4 bg-[var(--bg-card)] rounded-2xl border border-[var(--border)] hover:border-[var(--accent)] transition-colors card-hover">
        <div class="flex items-center gap-3">
          <span class="text-2xl">🎭</span>
          <div class="flex-1"><h3 class="font-semibold">Playwright AI</h3></div>
          <span class="text-[var(--accent)] font-bold">40 篇</span>
        </div>
        <p class="text-xs text-[var(--text-muted)] mt-2">Playwright + AI 驱动的浏览器自动化测试</p>
      </div>
      <div class="p-4 bg-[var(--bg-card)] rounded-2xl border border-[var(--border)] hover:border-[var(--accent)] transition-colors card-hover">
        <div class="flex items-center gap-3">
          <span class="text-2xl">🧪</span>
          <div class="flex-1"><h3 class="font-semibold">测试工程</h3></div>
          <span class="text-[var(--accent)] font-bold">37 篇</span>
        </div>
        <p class="text-xs text-[var(--text-muted)] mt-2">测试框架、工程实践、质量保障</p>
      </div>
      <div class="p-4 bg-[var(--bg-card)] rounded-2xl border border-[var(--border)] hover:border-[var(--accent)] transition-colors card-hover">
        <div class="flex items-center gap-3">
          <span class="text-2xl">📈</span>
          <div class="flex-1"><h3 class="font-semibold">投资与变现</h3></div>
          <span class="text-[var(--accent)] font-bold">36 篇</span>
        </div>
        <p class="text-xs text-[var(--text-muted)] mt-2">量化交易、Polymarket、投资策略</p>
      </div>
      <div class="p-4 bg-[var(--bg-card)] rounded-2xl border border-[var(--border)] hover:border-[var(--accent)] transition-colors card-hover">
        <div class="flex items-center gap-3">
          <span class="text-2xl">🌐</span>
          <div class="flex-1"><h3 class="font-semibold">浏览器自动化</h3></div>
          <span class="text-[var(--accent)] font-bold">27 篇</span>
        </div>
        <p class="text-xs text-[var(--text-muted)] mt-2">browser-use、Craw4AI、BrowserAct 等</p>
      </div>
      <div class="p-4 bg-[var(--bg-card)] rounded-2xl border border-[var(--border)] hover:border-[var(--accent)] transition-colors card-hover">
        <div class="flex items-center gap-3">
          <span class="text-2xl">🤖</span>
          <div class="flex-1"><h3 class="font-semibold">AI Skill</h3></div>
          <span class="text-[var(--accent)] font-bold">24 篇</span>
        </div>
        <p class="text-xs text-[var(--text-muted)] mt-2">AI 工具使用、Prompt Engineering 技巧</p>
      </div>
      <div class="p-4 bg-[var(--bg-card)] rounded-2xl border border-[var(--border)] hover:border-[var(--accent)] transition-colors card-hover">
        <div class="flex items-center gap-3">
          <span class="text-2xl">💡</span>
          <div class="flex-1"><h3 class="font-semibold">AI 理念与范式</h3></div>
          <span class="text-[var(--accent)] font-bold">23 篇</span>
        </div>
        <p class="text-xs text-[var(--text-muted)] mt-2">AI 产品理念、范式转变、行业思考</p>
      </div>
      <div class="p-4 bg-[var(--bg-card)] rounded-2xl border border-[var(--border)] hover:border-[var(--accent)] transition-colors card-hover">
        <div class="flex items-center gap-3">
          <span class="text-2xl">⌨️</span>
          <div class="flex-1"><h3 class="font-semibold">Claude Code & OpenCode</h3></div>
          <span class="text-[var(--accent)] font-bold">23 篇</span>
        </div>
        <p class="text-xs text-[var(--text-muted)] mt-2">编码代理工具的使用与集成</p>
      </div>
      <div class="p-4 bg-[var(--bg-card)] rounded-2xl border border-[var(--border)] hover:border-[var(--accent)] transition-colors card-hover">
        <div class="flex items-center gap-3">
          <span class="text-2xl">🚀</span>
          <div class="flex-1"><h3 class="font-semibold">Onboarding</h3></div>
          <span class="text-[var(--accent)] font-bold">21 篇</span>
        </div>
        <p class="text-xs text-[var(--text-muted)] mt-2">新手上路、工具初始化、配置指南</p>
      </div>
      <div class="p-4 bg-[var(--bg-card)] rounded-2xl border border-[var(--border)] hover:border-[var(--accent)] transition-colors card-hover">
        <div class="flex items-center gap-3">
          <span class="text-2xl">🧠</span>
          <div class="flex-1"><h3 class="font-semibold">AI Agent</h3></div>
          <span class="text-[var(--accent)] font-bold">15 篇</span>
        </div>
        <p class="text-xs text-[var(--text-muted)] mt-2">AI Agent 框架、Multi-Agent 模式</p>
      </div>
      <div class="p-4 bg-[var(--bg-card)] rounded-2xl border border-[var(--border)] hover:border-[var(--accent)] transition-colors card-hover">
        <div class="flex items-center gap-3">
          <span class="text-2xl">🔧</span>
          <div class="flex-1"><h3 class="font-semibold">开源工具</h3></div>
          <span class="text-[var(--accent)] font-bold">10 篇</span>
        </div>
        <p class="text-xs text-[var(--text-muted)] mt-2">各类开源项目与自建工具</p>
      </div>
      <div class="p-4 bg-[var(--bg-card)] rounded-2xl border border-[var(--border)] hover:border-[var(--accent)] transition-colors card-hover">
        <div class="flex items-center gap-3">
          <span class="text-2xl">⚡</span>
          <div class="flex-1"><h3 class="font-semibold">Hermes</h3></div>
          <span class="text-[var(--accent)] font-bold">10 篇</span>
        </div>
        <p class="text-xs text-[var(--text-muted)] mt-2">Hermes Agent 配置、插件、技能开发</p>
      </div>
    </div>

    <!-- Bottom info -->
    <div class="mt-8 pt-6 border-t border-[var(--border)]">
      <p class="text-center text-sm text-[var(--text-muted)]">
        📂 知识库存储在 <code class="text-[var(--accent)]">/root/Documents/Obsidian Vault/</code>
        · 由 Hybrid Web Scraper 自动采集 · 三层架构（采集→整理→输出）
      </p>
    </div>
  </div>
</BaseLayout>