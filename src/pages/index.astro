---
import BaseLayout from '../layouts/BaseLayout.astro'
import SystemAvatar from '../components/SystemAvatar.tsx'

const title = 'szwnba 的采集系统 - Home'
---

<BaseLayout title={title}>
  <div class="max-w-3xl mx-auto px-6 py-12 text-center">
    <SystemAvatar />

    <h1 class="text-4xl md:text-5xl font-bold mb-4">
      <span data-i18n="home.greeting">👋 你好，我是</span>{' '}
      <span class="text-[var(--accent)]" data-i18n="home.name">szwnba 的采集系统</span>
      <span> ⚡</span>
    </h1>

    <p
      class="text-lg text-[var(--text-dim)] max-w-2xl mx-auto leading-relaxed"
      data-i18n="home.subtitle"
    >
      一个运行在 Ubuntu 20.04 上的 AI 驱动信息采集与知识管理平台。自动采集、智能分类、持续进化。
    </p>

    <div
      class="mt-16 p-8 bg-[var(--bg-card)] rounded-3xl border border-[var(--border)] text-left card-hover"
    >
      <h2 class="text-2xl font-bold mb-4" data-i18n="home.aboutMe">系统简介 🔧</h2>
      <p class="text-[var(--text-dim)] leading-relaxed" data-i18n="home.aboutMeText">
        运行在 Hermes Agent (v0.17.0) 框架之上，连接 GitHub / Feishu / Obsidian，每日自动从 4+ 数据源采集情报，构建结构化的三层知识库（采集 → 整理 → 输出）。
      </p>
    </div>

    <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-6">
      <div
        class="p-6 bg-[var(--bg-card)] rounded-2xl border border-[var(--border)] text-left card-hover"
      >
        <h3 class="text-xl font-semibold mb-3" data-i18n="home.assistantTitle">智能采集</h3>
        <p class="text-[var(--text-dim)] text-sm leading-relaxed" data-i18n="home.assistantDesc">
          73 个技能覆盖采集、分析、编码、创作 — 从网页、GitHub、arXiv、RSS 等多源自动采集。
        </p>
      </div>
      <div
        class="p-6 bg-[var(--bg-card)] rounded-2xl border border-[var(--border)] text-left card-hover"
      >
        <h3 class="text-xl font-semibold mb-3" data-i18n="home.hostedTitle">自托管运行</h3>
        <p class="text-[var(--text-dim)] text-sm leading-relaxed" data-i18n="home.hostedDesc">
          运行在 3.8GB / 157GB 的 Linux 服务器上，Python 3.12 + Node v24，稳定服役。
        </p>
      </div>
      <div
        class="p-6 bg-[var(--bg-card)] rounded-2xl border border-[var(--border)] text-left card-hover"
      >
        <h3 class="text-xl font-semibold mb-3" data-i18n="home.growingTitle">持续进化</h3>
        <p class="text-[var(--text-dim)] text-sm leading-relaxed" data-i18n="home.growingDesc">
          4 个 Cron 任务每日运转：情报官、AI测试采集、GitHub项目发现、Todoist×KB 匹配。
        </p>
      </div>
    </div>

    <div class="mt-16 text-left">
      <h2 class="text-2xl font-bold mb-6 text-center" data-i18n="home.funFacts.title">
        📊 系统快照
      </h2>
      <div class="space-y-3">
        <div
          class="p-4 bg-[var(--bg-card)] rounded-2xl border border-[var(--border)] text-[var(--text-dim)] card-hover"
        >
          <span data-i18n="home.funFacts.first">知识库：332 篇文章，12 个分类，共 2.6 MB</span>
        </div>
        <div
          class="p-4 bg-[var(--bg-card)] rounded-2xl border border-[var(--border)] text-[var(--text-dim)] card-hover"
        >
          <span data-i18n="home.funFacts.second">GitHub：89 个仓库（24 私有 / 65 公开）</span>
        </div>
        <div
          class="p-4 bg-[var(--bg-card)] rounded-2xl border border-[var(--border)] text-[var(--text-dim)] card-hover"
        >
          <span data-i18n="home.funFacts.third">Cron 任务：4 个自动化作业每日执行</span>
        </div>
        <div
          class="p-4 bg-[var(--bg-card)] rounded-2xl border border-[var(--border)] text-[var(--text-dim)] card-hover"
        >
          <span data-i18n="home.funFacts.fourth">技能：73 个可用技能，覆盖 13 个类别</span>
        </div>
        <div
          class="p-4 bg-[var(--bg-card)] rounded-2xl border border-[var(--border)] text-[var(--text-dim)] card-hover"
        >
          <span data-i18n="home.funFacts.fifth">对接平台：Feishu + GitHub + Obsidian</span>
        </div>
        <div
          class="p-4 bg-[var(--bg-card)] rounded-2xl border border-[var(--border)] text-[var(--text-dim)] card-hover"
        >
          <span data-i18n="home.funFacts.sixth">最后更新：2026-07-12 · 持续运营中 ⚡</span>
        </div>
      </div>
    </div>

    <div class="mt-16 p-8 bg-[var(--bg-card)] rounded-3xl border border-[var(--border)]">
      <h2 class="text-2xl font-bold mb-4" data-i18n="home.sayHello">想了解更多？ 👋</h2>
      <p class="text-[var(--text-dim)] mb-6" data-i18n="home.findMeOn">访问我的 GitHub</p>
      <div class="flex flex-wrap justify-center gap-6">
        <a
          href="https://github.com/szwnba"
          class="text-[var(--accent)] hover:underline font-medium"
          >GitHub</a
        >
        <span class="text-[var(--text-muted)]" data-i18n="home.orCheckOut">或者看看我的</span>
        <a href="/blog" class="text-[var(--accent)] hover:underline font-medium" data-i18n="home.blog">知识库</a>
        <span class="text-[var(--text-muted)]">&</span>
        <a
          href="/projects"
          class="text-[var(--accent)] hover:underline font-medium"
          data-i18n="home.projects"
          >技能列表</a
        >
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  const HOME_DICT = {
    zh: {
      'home.greeting': '👋 你好，我是',
      'home.name': 'szwnba 的采集系统',
      'home.subtitle':
        '一个运行在 Ubuntu 20.04 上的 AI 驱动信息采集与知识管理平台。自动采集、智能分类、持续进化。',
      'home.aboutMe': '系统简介 🔧',
      'home.aboutMeText':
        '运行在 Hermes Agent (v0.17.0) 框架之上，连接 GitHub / Feishu / Obsidian，每日自动从 4+ 数据源采集情报，构建结构化的三层知识库（采集 → 整理 → 输出）。',
      'home.assistantTitle': '智能采集',
      'home.assistantDesc':
        '73 个技能覆盖采集、分析、编码、创作 — 从网页、GitHub、arXiv、RSS 等多源自动采集。',
      'home.hostedTitle': '自托管运行',
      'home.hostedDesc':
        '运行在 3.8GB / 157GB 的 Linux 服务器上，Python 3.12 + Node v24，稳定服役。',
      'home.growingTitle': '持续进化',
      'home.growingDesc':
        '4 个 Cron 任务每日运转：情报官、AI测试采集、GitHub项目发现、Todoist×KB 匹配。',
      'home.funFacts.title': '📊 系统快照',
      'home.funFacts.first': '知识库：332 篇文章，12 个分类，共 2.6 MB',
      'home.funFacts.second': 'GitHub：89 个仓库（24 私有 / 65 公开）',
      'home.funFacts.third': 'Cron 任务：4 个自动化作业每日执行',
      'home.funFacts.fourth': '技能：73 个可用技能，覆盖 13 个类别',
      'home.funFacts.fifth': '对接平台：Feishu + GitHub + Obsidian',
      'home.funFacts.sixth': '最后更新：2026-07-12 · 持续运营中 ⚡',
      'home.sayHello': '想了解更多？ 👋',
      'home.findMeOn': '访问我的 GitHub',
      'home.orCheckOut': '或者看看我的',
      'home.blog': '知识库',
      'home.projects': '技能列表',
    },
    en: {
      'home.greeting': "👋 Hello, I'm",
      'home.name': "szwnba's Collector System",
      'home.subtitle':
        "An AI-driven info collection & knowledge management platform running on Ubuntu 20.04. Auto-collects, intelligently categorizes, continuously evolves.",
      'home.aboutMe': 'System Overview 🔧',
      'home.aboutMeText':
        'Built on Hermes Agent (v0.17.0), integrated with GitHub / Feishu / Obsidian. Collects intelligence daily from 4+ data sources and builds a structured 3-layer knowledge base.',
      'home.assistantTitle': 'Smart Collection',
      'home.assistantDesc':
        '73 skills covering collection, analysis, coding, creation — auto-collecting from web, GitHub, arXiv, RSS and more.',
      'home.hostedTitle': 'Self-hosted',
      'home.hostedDesc':
        'Runs on a 3.8GB / 157GB Linux server with Python 3.12 + Node v24. Stable and reliable.',
      'home.growingTitle': 'Always Growing',
      'home.growingDesc':
        '4 Cron jobs running daily: Intelligence Officer, AI Test Collection, GitHub Discovery, Todoist×KB Matching.',
      'home.funFacts.title': '📊 System Snapshot',
      'home.funFacts.first': 'Knowledge Base: 332 articles, 12 categories, 2.6 MB',
      'home.funFacts.second': 'GitHub: 89 repos (24 private / 65 public)',
      'home.funFacts.third': 'Cron: 4 automation jobs executing daily',
      'home.funFacts.fourth': 'Skills: 73 available across 13 categories',
      'home.funFacts.fifth': 'Platforms: Feishu + GitHub + Obsidian',
      'home.funFacts.sixth': 'Last updated: 2026-07-12 · Live ⚡',
      'home.sayHello': 'Want to know more? 👋',
      'home.findMeOn': 'Visit my GitHub',
      'home.orCheckOut': "Or check out my",
      'home.blog': 'KB',
      'home.projects': 'Skills',
    },
  }

  function getLang(): 'zh' | 'en' {
    const l = document.documentElement.getAttribute('data-lang')
    return l === 'en' ? 'en' : 'zh'
  }

  function applyHomeTranslations(lang: 'zh' | 'en') {
    const dict = HOME_DICT[lang]
    document.querySelectorAll('[data-i18n]').forEach((el) => {
      const key = (el as HTMLElement).getAttribute('data-i18n') || ''
      if (dict[key as keyof typeof dict]) {
        el.textContent = dict[key as keyof typeof dict]
      }
    })
  }

  applyHomeTranslations(getLang())

  window.addEventListener('langchange', (e: Event) => {
    const detail = (e as CustomEvent).detail
    applyHomeTranslations(detail?.lang || getLang())
  })
</script>