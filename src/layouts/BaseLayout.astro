---
import '../styles/global.css'
import ThemeToggle from '../components/ThemeToggle.astro'
import LanguageSwitcher from '../components/LanguageSwitcher.astro'
import { t, DEFAULT_LANG, type Lang } from '../i18n'

interface Props {
  title: string
  description?: string
  ogImage?: string
  pageLang?: Lang
}

const {
  title,
  description,
  ogImage = '/og-image.jpg',
  pageLang = DEFAULT_LANG,
} = Astro.props

const defaultDesc =
  pageLang === 'zh'
    ? 'szwnba 的采集系统 —— AI 驱动的信息采集与知识管理平台。⚡'
    : "szwnba's Collector System — An AI-driven info collection & knowledge management platform. ⚡"

const canonicalURL = new URL(Astro.url.pathname, Astro.site)
---

<!doctype html>
<html lang={pageLang} data-lang={pageLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      rel="icon"
      href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>⚡</text></svg>"
    />
    <meta name="theme-color" content="#1a2e1f" />
    <meta name="description" content={description ?? defaultDesc} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description ?? defaultDesc} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description ?? defaultDesc} />

    <link rel="canonical" href={canonicalURL} />
    <title>{title}</title>
  </head>
  <body>
    <div class="gradient-bg min-h-screen">
      <nav class="fixed top-0 w-full z-50 backdrop-blur-md bg-[var(--bg)]/90 border-b border-[var(--border)]">
        <div class="max-w-4xl mx-auto px-6 py-4 flex items-center justify-between">
          <a
            href="/"
            class="flex items-center gap-2 text-xl font-semibold hover:text-[var(--accent)] transition-colors"
          >
            <span class="text-2xl">⚡</span>
            <span data-i18n="nav.home">{t('nav.home', pageLang)}</span>
          </a>
          <div class="flex items-center gap-3 sm:gap-6 text-sm sm:text-base">
            <a
              href="/about"
              class="text-[var(--text-dim)] hover:text-[var(--accent)] transition-colors link-underline"
              data-i18n="nav.about"
              >{t('nav.about', pageLang)}</a
            >
            <a
              href="/projects"
              class="text-[var(--text-dim)] hover:text-[var(--accent)] transition-colors link-underline"
              data-i18n="nav.projects"
              >{t('nav.projects', pageLang)}</a
            >
            <a
              href="/blog"
              class="text-[var(--text-dim)] hover:text-[var(--accent)] transition-colors link-underline"
              data-i18n="nav.blog"
              >{t('nav.blog', pageLang)}</a
            >
            <a
              href="/report"
              class="text-[var(--text-dim)] hover:text-[var(--accent)] transition-colors link-underline"
              data-i18n="nav.report"
              >{t('nav.report', pageLang)}</a
            >
            <a
              href="/todoist"
              class="text-[var(--text-dim)] hover:text-[var(--accent)] transition-colors link-underline"
              data-i18n="nav.todoist"
              >{t('nav.todoist', pageLang)}</a
            >
            <LanguageSwitcher />
            <ThemeToggle />
          </div>
        </div>
      </nav>

      <main class="pt-20">
        <slot />
      </main>

      <footer class="border-t border-[var(--border)] mt-20 bg-[var(--bg-darker)]">
        <div class="max-w-4xl mx-auto px-6 py-8 text-center text-[var(--text-muted)] text-sm">
          <p data-i18n="footer.madeWith">
            {pageLang === 'zh'
              ? 'szwnba 的采集系统 · Hermes Agent v0.17.0 ⚡'
              : "szwnba's Collector System · Hermes Agent v0.17.0 ⚡"}
          </p>
          <p class="mt-2 flex items-center justify-center gap-4">
            <span data-i18n="footer.rightsReserved">
              © {new Date().getFullYear()} szwnba.github.io
            </span>
            <a href="/rss.xml" class="text-[var(--accent)] hover:underline">RSS</a>
          </p>
        </div>
      </footer>
    </div>

    <script>
      // ---- Theme initialization ----
      const getInitialTheme = () => {
        const saved = localStorage.getItem('theme')
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches
        return saved ? saved === 'dark' : prefersDark
      }
      document.documentElement.setAttribute(
        'data-theme',
        getInitialTheme() ? 'dark' : 'light'
      )

      // ---- Language initialization ----
      const getInitialLang = () => {
        const saved = localStorage.getItem('lang')
        if (saved === 'zh' || saved === 'en') return saved
        // Default to Chinese
        return 'zh'
      }
      document.documentElement.setAttribute('data-lang', getInitialLang())

      // ---- Translation dictionaries (inlined client-side) ----
      const DICT = {
        zh: {
          'nav.home': '首页',
          'nav.about': '系统',
          'nav.projects': '技能',
          'nav.blog': '知识库',
          'nav.report': '分析报告',
          'nav.todoist': '任务',
          'footer.madeWith': 'szwnba 的采集系统 · Hermes Agent v0.17.0 ⚡',
          'footer.rightsReserved': '© ' + new Date().getFullYear() + ' szwnba.github.io',
        },
        en: {
          'nav.home': 'Home',
          'nav.about': 'System',
          'nav.projects': 'Skills',
          'nav.blog': 'KB',
          'nav.report': 'Report',
          'nav.todoist': 'Tasks',
          'footer.madeWith': "szwnba's Collector System · Hermes Agent v0.17.0 ⚡",
          'footer.rightsReserved': '© ' + new Date().getFullYear() + ' szwnba.github.io',
        },
      }

      // ---- Live translation swap ----
      function applyTranslations(lang: 'zh' | 'en') {
        const dict = DICT[lang]
        document.querySelectorAll('[data-i18n]').forEach((el) => {
          const key = (el as HTMLElement).getAttribute('data-i18n') || ''
          if (dict[key as keyof typeof dict]) {
            el.textContent = dict[key as keyof typeof dict]
          }
        })
      }

      function getLang(): 'zh' | 'en' {
        const l = document.documentElement.getAttribute('data-lang')
        return l === 'en' ? 'en' : 'zh'
      }

      applyTranslations(getLang())

      window.addEventListener('langchange', (e: Event) => {
        const detail = (e as CustomEvent).detail
        const lang = detail?.lang || getLang()
        applyTranslations(lang)
      })
    </script>
  </body>
</html>